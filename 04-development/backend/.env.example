# 后端环境变量示例 —— 复制为 .env 并填入真实值
# 统一使用 LLM_ 前缀，避免被系统已有的 ANTHROPIC_* 环境变量劫持

# API Key（仅服务端持有，前端不接触）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# 自定义 base_url：官方留空；使用 Anthropic 兼容中转/代理时填其地址
# 例如 https://api.cisct.xyz （SDK 会自动补 /v1/messages）
LLM_BASE_URL=

# 主模型；fallback 留空表示不降级
LLM_MODEL=claude-opus-4-8
LLM_FALLBACK_MODEL=

# 运行时配置
LLM_UPLOAD_DIR=./_uploads
LLM_FILE_TTL_DAYS=7
LLM_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
